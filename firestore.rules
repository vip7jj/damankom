rules_version = '2';

// ============================================================
// ضمانكم — قواعد أمان Firestore (النسخة الصحيحة الكاملة)
// انسخ كامل هذا المحتوى والصقه في:
// Firebase Console ← Firestore Database ← تبويب Rules ← Publish
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // كل مستخدم يقرأ ويكتب بياناته (ضماناته وصوره) فقط — لا أحد غيره
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // الإعدادات العامة (الإعلانات، رقم التواصل، الماركات، مراكز الصيانة، أنواع المنتجات):
    // الجميع يقرأ (حتى الزائر المجهول)، والأدمن فقط يكتب/يعدّل
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // اقتراحات المستخدمين (ماركات/منتجات جديدة):
    // أي مستخدم مسجّل (ولو مجهولاً) ينشئ اقتراحاً، والأدمن فقط يقرؤها ويديرها
    match /suggestions/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // الأدمن = من سجّل دخوله ببريد الأدمن
    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'vip7jj@gmail.com';
    }
  }
}
