rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // كل مستخدم يقرأ ويكتب بياناته (ضماناته وصوره) فقط — لا أحد غيره
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // الإعدادات العامة (إعلانات، رقم تواصل): الجميع يقرأ، الأدمن فقط يكتب
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // اقتراحات المستخدمين: أي مستخدم مسجّل ينشئ اقتراحاً، والأدمن فقط يقرؤها ويديرها
    match /suggestions/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // الأدمن = من سجّل دخوله ببريد الأدمن
    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'vip7jj@gmail.com';
    }
  }
}